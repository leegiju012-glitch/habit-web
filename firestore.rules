rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validNickname(n) {
      return n is string && n.size() >= 2 && n.size() <= 10;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "leegiju012@gmail.com";
    }

    // users/{uid}
    // - 본인은 자신의 프로필/닉네임/토큰/그룹 상태를 수정 가능
    // - 매칭 트랜잭션을 위해, queue에 있는 유저의 currentGroupId 설정은 로그인 사용자에게 허용
    match /users/{uid} {
      allow read: if signedIn();

      allow create: if isOwner(uid);

      allow update: if (
          isOwner(uid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "name",
            "nickname",
            "email",
            "photoURL",
            "fcmToken",
            "currentGroupId",
            "currentGroupInviteCode",
            "currentChallengeStreak",
            "lastChallengeStreak"
          ])
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["nickname"])
            || validNickname(request.resource.data.nickname)
          )
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["currentChallengeStreak"])
            || (request.resource.data.currentChallengeStreak is int && request.resource.data.currentChallengeStreak >= 0)
          )
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["lastChallengeStreak"])
            || (request.resource.data.lastChallengeStreak is int && request.resource.data.lastChallengeStreak >= 0)
          )
        )
        || (
          signedIn()
          && exists(/databases/$(database)/documents/queue/$(uid))
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["currentGroupId", "currentGroupInviteCode"])
          && resource.data.currentGroupId == null
          && request.resource.data.currentGroupId is string
          && request.resource.data.currentGroupInviteCode == null
        )
        || (
          signedIn()
          && resource.data.currentGroupId is string
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["currentGroupId", "currentGroupInviteCode"])
          && request.resource.data.currentGroupId == null
          && request.resource.data.currentGroupInviteCode == null
          && exists(/databases/$(database)/documents/groups/$(resource.data.currentGroupId))
          && get(/databases/$(database)/documents/groups/$(resource.data.currentGroupId)).data.ownerUid == request.auth.uid
        );
    }

    // queue/{uid}
    // - 본인은 자신의 대기열 등록 가능
    // - 매칭 트랜잭션에서 여러 유저 queue 삭제가 필요하므로 로그인 사용자 삭제 허용
    match /queue/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid);
      allow delete: if signedIn();
    }

    // groups/{groupId}
    // - 생성/입장은 Cloud Functions(Admin SDK)에서 처리
    // - 클라이언트는 읽기 + 제한된 상태변경/자기 자신 나가기만 허용
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if false;
      allow update: if signedIn() && (
        // 방장: waiting -> active 시작
        (
          request.auth.uid == resource.data.ownerUid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "startedAt"])
          && resource.data.status == "waiting"
          && request.resource.data.status == "active"
          && request.resource.data.members == resource.data.members
        )
        ||
        // 방장: waiting/active -> closed 해산
        (
          request.auth.uid == resource.data.ownerUid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "closedAt"])
          && (resource.data.status == "waiting" || resource.data.status == "active")
          && request.resource.data.status == "closed"
          && request.resource.data.members == resource.data.members
        )
        ||
        // 멤버: 자기 자신 나가기(멤버 추가 금지)
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["members"])
          && resource.data.members is list
          && request.resource.data.members is list
          && resource.data.members.hasAny([request.auth.uid])
          && !request.resource.data.members.hasAny([request.auth.uid])
          && request.resource.data.members.size() == resource.data.members.size() - 1
          && resource.data.members.hasAll(request.resource.data.members)
        )
      );
      allow delete: if signedIn()
        && resource.data.mode != "random"
        && resource.data.ownerUid == request.auth.uid
        && resource.data.members is list
        && resource.data.members.size() < 2;
    }

    // 비밀번호 해시/솔트는 서버 전용 컬렉션
    match /groupSecrets/{groupId} {
      allow read, write: if false;
    }

    // checkins/{groupId_uid_date}
    // - 본인 체크인만 생성/수정 가능
    // - 읽기는 로그인 사용자 허용 (그룹 화면 렌더링용)
    match /checkins/{checkinId} {
      allow read: if signedIn()
        && resource.data.groupId is string
        && exists(/databases/$(database)/documents/groups/$(resource.data.groupId))
        && get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.members.hasAny([request.auth.uid]);

      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.groupId is string
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.currentGroupId == request.resource.data.groupId
        && (
          // 본인 제출/재제출은 항상 pending만 허용 (승인/반려는 서버 함수 전용)
          request.resource.data.status == "pending"
          && (
            !request.resource.data.keys().hasAny(["reviewedBy"])
            || request.resource.data.reviewedBy == null
          )
          && (
            !request.resource.data.keys().hasAny(["reviewedAt"])
            || request.resource.data.reviewedAt == null
          )
          && (
            !request.resource.data.keys().hasAny(["streakCounted"])
            || request.resource.data.streakCounted == false
          )
          && (
            !request.resource.data.keys().hasAny(["approvals"])
            || request.resource.data.approvals.size() == 0
          )
          && (
            !request.resource.data.keys().hasAny(["rejections"])
            || request.resource.data.rejections.size() == 0
          )
        );
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // clientErrors/{autoId}
    // - 클라이언트 실패 이벤트 로그(운영 대시보드용)
    match /clientErrors/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type is string
        && request.resource.data.message is string
        && request.resource.data.page is string
        && request.resource.data.keys().hasOnly([
          "uid",
          "type",
          "message",
          "code",
          "page",
          "extra",
          "createdAt"
        ]);
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
